# Local release-signing config. Copy this to `keystore.properties`
# (same directory, no `.example`) and fill in real values.
#
# This file is for LOCAL release builds only. CI gets the same data
# from GitHub Secrets and exports them as environment variables.
#
# DO NOT COMMIT keystore.properties OR the .jks file. They are
# gitignored at the repo root.

storeFile=/absolute/path/to/global-radio-release.jks
storePassword=REPLACE_ME
keyAlias=global-radio-release
keyPassword=REPLACE_ME
